# Public environment variables (NEXT_PUBLIC_*) for the simulator.eic-jp.org project.
# Copy this file to .env.local and fill in real values for local development.
# Vercel: set the same keys under Settings → Environment Variables for Production / Preview / Development.

# Supabase (anon key — public, safe to commit values for staging if needed)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Microsoft Clarity (heatmap / session recording)
# Project ID is publicly embedded in the page script tag, so it is safe as a NEXT_PUBLIC_* var.
NEXT_PUBLIC_CLARITY_PROJECT_ID=whkcu4l94w
